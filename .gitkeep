import SwiftUI

/// A SwiftUI recreation of the provided minimalist living-room JPEG.
/// Drop this file into your iOS app target and present `LivingRoomSceneView()`.
struct LivingRoomSceneView: View {
    var body: some View {
        GeometryReader { geo in
            ZStack {
                // Wall
                LinearGradient(
                    colors: [Color(red: 0.96, green: 0.94, blue: 0.90), Color(red: 0.93, green: 0.90, blue: 0.85)],
                    startPoint: .top,
                    endPoint: .bottom
                )
                .ignoresSafeArea()

                VStack(spacing: 0) {
                    Spacer(minLength: geo.size.height * 0.62)

                    // Floor section
                    ParquetFloor()
                        .frame(height: geo.size.height * 0.38)
                }

                // Main decor composition
                ZStack(alignment: .bottom) {
                    HStack(alignment: .bottom, spacing: geo.size.width * 0.04) {
                        WindowPanel()
                            .frame(width: geo.size.width * 0.16, height: geo.size.height * 0.48)

                        WindowPanel()
                            .frame(width: geo.size.width * 0.18, height: geo.size.height * 0.50)

                        Spacer(minLength: geo.size.width * 0.04)

                        CouchView()
                            .frame(width: geo.size.width * 0.42, height: geo.size.height * 0.26)
                    }
                    .padding(.horizontal, geo.size.width * 0.08)
                    .padding(.bottom, geo.size.height * 0.14)

                    CoffeeTable()
                        .frame(width: geo.size.width * 0.27, height: geo.size.height * 0.08)
                        .offset(y: -geo.size.height * 0.06)
                }

                WallArtAndShelves()
                    .frame(width: geo.size.width, height: geo.size.height)
            }
        }
    }
}

private struct WindowPanel: View {
    var body: some View {
        ZStack {
            RoundedRectangle(cornerRadius: 2)
                .fill(Color(red: 0.70, green: 0.58, blue: 0.46))

            RoundedRectangle(cornerRadius: 2)
                .inset(by: 7)
                .fill(Color(red: 0.89, green: 0.92, blue: 0.89))

            // Muntins
            VStack(spacing: 0) {
                Rectangle().fill(frameColor).frame(height: 4)
                Spacer()
                Rectangle().fill(frameColor).frame(height: 4)
                Spacer()
                Rectangle().fill(frameColor).frame(height: 4)
            }
            .padding(.vertical, 20)

            HStack(spacing: 0) {
                Rectangle().fill(frameColor).frame(width: 4)
                Spacer()
                Rectangle().fill(frameColor).frame(width: 4)
                Spacer()
                Rectangle().fill(frameColor).frame(width: 4)
            }
            .padding(.horizontal, 20)
        }
        .overlay(alignment: .bottom) {
            RoundedRectangle(cornerRadius: 2)
                .fill(frameColor)
                .frame(height: 10)
                .offset(y: 9)
        }
    }

    private var frameColor: Color {
        Color(red: 0.76, green: 0.63, blue: 0.51)
    }
}

private struct WallArtAndShelves: View {
    var body: some View {
        GeometryReader { geo in
            ZStack(alignment: .topTrailing) {
                // Picture frame
                RoundedRectangle(cornerRadius: 2)
                    .stroke(Color(red: 0.70, green: 0.58, blue: 0.46), lineWidth: 3)
                    .frame(width: geo.size.width * 0.09, height: geo.size.height * 0.14)
                    .overlay {
                        ZStack {
                            Color(red: 0.95, green: 0.92, blue: 0.86)
                            Circle().fill(Color(red: 0.86, green: 0.82, blue: 0.74)).frame(width: 24)
                            Circle().fill(Color(red: 0.34, green: 0.41, blue: 0.32)).frame(width: 28).offset(x: 8, y: 15)
                        }
                    }
                    .offset(x: -geo.size.width * 0.39, y: geo.size.height * 0.21)

                VStack(spacing: geo.size.height * 0.09) {
                    ShelfView(items: 5)
                    ShelfView(items: 6)
                }
                .offset(x: -geo.size.width * 0.1, y: geo.size.height * 0.24)
            }
        }
    }
}

private struct ShelfView: View {
    let items: Int

    var body: some View {
        ZStack(alignment: .top) {
            RoundedRectangle(cornerRadius: 2)
                .fill(Color(red: 0.73, green: 0.60, blue: 0.47))
                .frame(width: 170, height: 8)
                .shadow(color: .black.opacity(0.08), radius: 4, y: 4)

            HStack(spacing: 8) {
                ForEach(0..<items, id: \.self) { i in
                    RoundedRectangle(cornerRadius: 2)
                        .fill(i % 2 == 0 ? Color(red: 0.72, green: 0.57, blue: 0.42) : Color(red: 0.30, green: 0.38, blue: 0.34))
                        .frame(width: 10, height: CGFloat(12 + (i % 3) * 8))
                }
            }
            .offset(y: -10)
        }
    }
}

private struct CouchView: View {
    var body: some View {
        HStack(spacing: 2) {
            couchSection
            couchSection
        }
    }

    private var couchSection: some View {
        ZStack(alignment: .bottom) {
            RoundedRectangle(cornerRadius: 20)
                .fill(Color(red: 0.17, green: 0.31, blue: 0.22))

            RoundedRectangle(cornerRadius: 14)
                .fill(Color(red: 0.19, green: 0.35, blue: 0.24))
                .frame(height: 80)
                .padding(.horizontal, 10)
                .padding(.bottom, 8)

            // Pillow
            RoundedRectangle(cornerRadius: 8)
                .fill(Color(red: 0.73, green: 0.62, blue: 0.50))
                .frame(width: 64, height: 46)
                .offset(x: -20, y: -28)
        }
        .overlay(alignment: .bottomLeading) {
            Capsule()
                .fill(Color(red: 0.17, green: 0.31, blue: 0.22))
                .frame(width: 26, height: 80)
                .offset(x: -8, y: -10)
        }
    }
}

private struct CoffeeTable: View {
    var body: some View {
        ZStack(alignment: .top) {
            RoundedRectangle(cornerRadius: 8)
                .fill(Color(red: 0.34, green: 0.20, blue: 0.12))
                .shadow(color: .black.opacity(0.14), radius: 6, y: 4)

            RoundedRectangle(cornerRadius: 8)
                .stroke(Color(red: 0.42, green: 0.26, blue: 0.16), lineWidth: 2)

            HStack {
                RoundedRectangle(cornerRadius: 3).fill(Color(red: 0.30, green: 0.18, blue: 0.10)).frame(width: 12)
                Spacer()
                RoundedRectangle(cornerRadius: 3).fill(Color(red: 0.30, green: 0.18, blue: 0.10)).frame(width: 12)
            }
            .padding(.horizontal, 24)
            .offset(y: 22)
        }
    }
}

private struct ParquetFloor: View {
    var body: some View {
        GeometryReader { geo in
            let tileW = geo.size.width / 8
            let tileH = geo.size.height / 4

            ZStack {
                Color(red: 0.70, green: 0.55, blue: 0.39)

                ForEach(0..<4, id: \.self) { row in
                    ForEach(0..<8, id: \.self) { col in
                        let vertical = (row + col) % 2 == 0
                        RoundedRectangle(cornerRadius: 1)
                            .fill(Color(red: 0.73, green: 0.58, blue: 0.41).opacity(0.80))
                            .frame(width: vertical ? tileW * 0.45 : tileW * 0.9,
                                   height: vertical ? tileH * 0.9 : tileH * 0.45)
                            .position(x: tileW * (CGFloat(col) + 0.5), y: tileH * (CGFloat(row) + 0.5))
                    }
                }
            }
        }
    }
}

#Preview {
    LivingRoomSceneView()
        .frame(width: 1024, height: 1024)
}


